---
import Button from "../components/Button";
import Layout from "../layouts/Layout.astro";
const API_BASE = import.meta.env.PUBLIC_API_BASE;
---

<Layout title="Acceso de Barberos">
  <div class="py-10 px-4 flex flex-col items-center mt-22 animate-fadeIn">
    <!-- Beautiful Header Logo / Icon -->
    <div
      class="w-16 h-16 rounded-full bg-accent/10 border border-accent/30 flex items-center justify-center text-3xl mb-4 shadow-lg shadow-accent/5"
    >
      💈
    </div>

    <h1 class="text-2xl font-serif font-bold text-white mb-1">
      Acceso Barberos
    </h1>
    <p class="text-xs text-secondary mb-8 text-center max-w-xs">
      Ingresa tus credenciales autorizadas para gestionar tus citas diarias y
      registrar pagos.
    </p>

    <!-- Login Card -->
    <div
      class="w-full max-w-sm bg-surface/20 border border-surface/40 p-6 rounded-2xl shadow-xl"
    >
      <div
        id="alert-box"
        class="hidden mb-4 p-3 rounded-xl text-xs font-semibold"
      >
      </div>

      <form id="login-form" method="post" class="flex flex-col gap-4">
        <div>
          <label
            for="email"
            class="block text-[11px] font-semibold text-secondary uppercase tracking-wider mb-1.5"
            >Correo Electrónico</label
          >
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="ej. carlos@barberia.com"
            class="w-full px-4 py-3 rounded-xl bg-surface/30 border border-surface focus:border-accent focus:ring-1 focus:ring-accent text-sm text-primary placeholder:text-secondary outline-none transition-all"
          />
        </div>

        <div>
          <div class="flex justify-between items-center mb-1.5">
            <label
              for="password"
              class="block text-[11px] font-semibold text-secondary uppercase tracking-wider"
              >Contraseña</label
            >
          </div>
          <input
            type="password"
            id="password"
            name="password"
            required
            placeholder="••••••••"
            class="w-full px-4 py-3 rounded-xl bg-surface/30 border border-surface focus:border-accent focus:ring-1 focus:ring-accent text-sm text-primary placeholder:text-secondary outline-none transition-all"
          />
        </div>

        <Button
          id="submit-btn"
          type="submit"
          variant="primary"
          nClass="w-full mt-2 py-4 px-1"
        >
          <span id="btn-text">Ingresar al Dashboard</span>
          <div
            id="btn-spinner"
            class="hidden w-4 h-4 border-2 border-surface border-t-transparent rounded-full animate-spin order-1"
          >
          </div>
        </Button>
      </form>
      <p class="text-center text-[12px] text-secondary mt-4">
        ¿Eres superusuario? <a
          href="/admin-login"
          class="text-accent hover:underline">Accede aquí</a
        >.
      </p>
    </div>
  </div>

  <script define:vars={{ API_BASE }} is:inline>
    const form = document.getElementById("login-form");
    const alertBox = document.getElementById("alert-box");
    const submitBtn = document.getElementById("submit-btn");
    const btnText = document.getElementById("btn-text");
    const btnSpinner = document.getElementById("btn-spinner");

    const loginUrl = new URL("/auth/login", API_BASE).toString();

    // Clear previous sessions
    localStorage.removeItem("barber");

    function showAlert(message, type = "error") {
      alertBox.classList.remove(
        "hidden",
        "bg-error/10",
        "border-error/20",
        "text-error",
        "bg-accent/10",
        "border-accent/20",
        "text-accent",
      );
      if (type === "error") {
        alertBox.classList.add(
          "bg-error/10",
          "border",
          "border-error/20",
          "text-error",
        );
        alertBox.innerHTML = `⚠️ ${message}`;
      } else {
        alertBox.classList.add(
          "bg-accent/10",
          "border",
          "border-accent/20",
          "text-accent",
        );
        alertBox.innerHTML = `ℹ️ ${message}`;
      }
    }

    if (form) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const email = document.getElementById("email").value.trim();
        const password = document.getElementById("password").value;

        submitBtn.disabled = true;
        btnSpinner.classList.remove("hidden");
        btnText.textContent = "Verificando...";
        alertBox.classList.add("hidden");

        try {
          const response = await fetch(loginUrl, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email, password }),
          });

          if (!response.ok) {
            const errorBody = await response.json().catch(() => ({}));
            throw new Error(errorBody.message || "Error al iniciar sesión.");
          }

          const data = await response.json();

          // Guardar datos de barber con access_token
          const barberData = {
            ...data.barber,
            access_token: data.access_token,
          };

          localStorage.setItem("barber", JSON.stringify(barberData));

          window.location.replace("/dashboard");
        } catch (err) {
          console.warn("Login falló en el backend.", err);
          showAlert(
            err.message || "Credenciales incorrectas o servidor no disponible.",
          );
        } finally {
          submitBtn.disabled = false;
          btnSpinner.classList.add("hidden");
          btnText.textContent = "Ingresar al Dashboard";
        }
      });
    }
  </script>
</Layout>
