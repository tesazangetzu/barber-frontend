---
import BarberDashboard from '../components/BarberDashboard';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dashboard del Barbero">
  <div class="py-6">
    <div class="flex items-center gap-2 mb-6 justify-between">
      <div class="flex items-center gap-2">
        <div class="p-2 rounded-lg bg-surface text-secondary">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 1 1-3 0m3 0a1.5 1.5 0 1 0-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-9.75 0h9.75" />
          </svg>
        </div>
        <div>
          <h1 class="text-xl font-serif font-bold text-white leading-tight">Panel de Control</h1>
          <p class="text-[10px] uppercase font-bold text-accent tracking-wider">Agenda de Barbería</p>
        </div>
      </div>
      
      <!-- Live Badge Indicator -->
      <span class="inline-flex items-center gap-1 bg-success/10 text-success border border-success/20 text-[9px] px-2 py-0.5 rounded-full font-bold uppercase tracking-wider">
        <span class="w-1.5 h-1.5 rounded-full bg-success animate-pulse"></span>
        En Vivo
      </span>
    </div>

    <!-- Barber Dashboard Interactive Island -->
    <div class="bg-surface/20 border border-surface/40 p-5 rounded-2xl shadow-xl">
      <BarberDashboard client:load />
    </div>
  </div>
</Layout>
