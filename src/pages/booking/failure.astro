---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Pago Fallido">
  <div class="py-12 flex flex-col items-center justify-center text-center animate-fadeIn">
    <!-- Red Warning Badge -->
    <div class="w-20 h-20 rounded-full bg-error/10 border-2 border-error flex items-center justify-center text-4xl mb-6 shadow-lg shadow-error/15 animate-bounce">
      ❌
    </div>

    <h1 class="text-2xl font-serif font-bold text-white tracking-wide leading-tight mb-2">
      ¡Pago Rechazado!
    </h1>
    <p class="text-xs text-secondary max-w-xs mb-8 leading-relaxed">
      Lo sentimos, no pudimos procesar tu pago en línea a través de MercadoPago. Esto puede deberse a fondos insuficientes o rechazo del banco.
    </p>

    <!-- Suggestion Box -->
    <div class="w-full max-w-sm bg-surface/40 border border-surface p-6 rounded-2xl text-left shadow-xl relative overflow-hidden mb-8">
      <div class="absolute top-0 left-0 right-0 h-1.5 bg-linear-to-r from-error via-error/90 to-error"></div>
      
      <h3 class="text-xs font-semibold text-secondary uppercase tracking-wider mb-3 border-b border-surface/60 pb-2">
        ¿Qué puedes hacer?
      </h3>

      <ul class="flex flex-col gap-2.5 text-xs text-secondary">
        <li class="flex gap-2">
          <span>🔄</span>
          <span>Intenta pagar de nuevo con otra tarjeta o medio de pago.</span>
        </li>
        <li class="flex gap-2">
          <span>💵</span>
          <span>Selecciona <strong>Pago Local</strong> al agendar y liquida directamente en la barbería en efectivo o terminal física.</span>
        </li>
      </ul>
    </div>

    <div class="flex flex-col gap-3 w-full">
      <a href="/booking" class="w-full py-3.5 rounded-xl bg-accent text-surface font-bold hover:bg-accent/90 active:scale-[0.98] transition-all text-center text-sm">
        Intentar Reservar Nuevamente
      </a>
      <a href="/" class="w-full py-3.5 rounded-xl border border-surface hover:bg-surface text-secondary font-bold transition-all text-center text-sm">
        Volver al Inicio
      </a>
    </div>
  </div>
</Layout>
